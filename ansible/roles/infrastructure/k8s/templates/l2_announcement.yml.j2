{# Manifest for the INDEF L2 Announcement Policy #}
apiVersion: cilium.io/v2alpha1
kind: CiliumL2AnnouncementPolicy
metadata:
  name: {{ cluster_name }}-l2-policy
spec:
  nodeSelector:
    matchExpressions:
    - key: node-role.kubernetes.io/control-plane
      operator: DoesNotExist
  interfaces:
  - ens18
  externalIPs: true
  loadBalancerIPs: true
  serviceSelector:
    matchLabels:
      io.cilium.gateway/owning-gateway: {{ cluster_name }}-gateway
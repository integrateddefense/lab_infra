# Core_Protected -> Core
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.core.id }}" tcp dport { 53,88,135,389,445,636,3268,3269,5722,9389,49152-65535 } accept
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.core.id }}" udp dport { 53,88,123,389 } accept
## Talos/K8s Rules
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.core.id }}" tcp dport { 4240,10250 } accept
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.core.id }}" udp dport { 4240,8472 } accept
add rule inet filter fwd_v{{ vlans.core_protected.id }} ip saddr { {{ components.talos.primary_cluster.control_plane | map(attribute="ip.service") | join(", ") }} } oifname "{{ trunk_iface }}.{{ vlans.core.id }}" ip daddr { {{ components.talos.primary_cluster.data_plane | map(attribute="ip.service") | join(", ") }} } icmp accept

# Core_Protected -> Transit DMZ
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.transit.dmz.id }}" tcp dport { 443 } accept
add rule inet filter fwd_v{{ vlans.core_protected.id }} oifname "{{ trunk_iface }}.{{ vlans.transit.dmz.id }}" udp dport { 53,123 } accept

# Default rule for the Core Protected VLAN
add rule inet filter fwd_v{{ vlans.core_protected.id }} log prefix "{{ nft_prefix }}" drop

# MGMT -> Transit DMZ
add rule inet filter fwd_v{{ vlans.mgmt.id }} oifname "{{ trunk_iface }}.{{ vlans.transit.dmz.id }}" accept

# MGMT -> DMZ
add rule inet filter fwd_v{{ vlans.mgmt.id }} oifname "{{ trunk_iface }}.{{ vlans.dmz.id }}" tcp dport { 22,443 } accept

# MGMT -> Core
add rule inet filter fwd_v{{ vlans.mgmt.id }} oifname "{{ trunk_iface }}.{{ vlans.core.id }}" tcp dport { 22,443 } accept

# MGMT -> Core_Protected
add rule inet filter fwd_v{{ vlans.mgmt.id }} oifname "{{ trunk_iface }}.{{ vlans.core_protected.id }}" tcp dport { 22,443 } accept

# MGMT -> Users
add rule inet filter fwd_v{{ vlans.mgmt.id }} oifname "{{ trunk_iface }}.{{ vlans.user.id }}" tcp dport { 22,443 } accept

# Default rule for the Management VLAN
add rule inet filter fwd_v{{ vlans.mgmt.id }} drop

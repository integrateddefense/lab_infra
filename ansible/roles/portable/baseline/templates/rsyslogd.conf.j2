ruleset(name="forward_to_collector"){
{% for collector in components.analysis.syslog_collectors %}
  action(
    type="omfwd"
    name="{{ collector.name }}"
    target="{{ collector.name }}"
    port="6514"
    protocol="tcp"
    streamDriver="gtls"
    streamDriverMode="1"
    streamDriverAuthMode="x509/name"
    streamDriver.CaFile="{{ enterprise_ca_path }}"
    action.resumeRetryCount="-1"
    queue.type="linkedList"
    queue.filename="{{ collector.name }}_primary_q"
  )
{% endfor %}
}

module(load="imfile")
{% for item in monitored_paths %}
{% if item.path == '/var/log/secure' %}
if $syslogfacility-text == 'local7' and not ($msg contains 'type=CRYPTO_KEY_USER' or $msg contains 'type=CRYPTO_SESSION' or $msg contains 'type=CRED_DISP' or $msg contains 'type=CRED_REFR' or $msg contains 'type=BPF' or $msg contains 'type=EOE') then {
    call forward_to_collector
}
{% else if item.path != '/var/log/audit/audit.log' %}
input(
  type="imfile"
  File="{{ item.path }}"
  Tag="{{ item.tag }}"
  Severity="{{ item.severity | default('info') }}"
  Facility="{{ item.facility | default('local0') }}"
  ruleset="forward_to_collector"
)

{% endif %}
{% endfor %}

concurrent = 1
check_interval = 0
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

[[runners]]
  name = "{{ runner_name }}"
  url = "{{ external_url }}"
  token = "{{ runner.runner.token }}"
  executor = "docker"
{# TODO - remove below once enterprise CA is available #}
  tls-ca-file = "/etc/gitlab-runner/certs/gitlab.ops.indef.space.crt"
{# TODO - remove above once enterprise CA is available #}

  limit = 1
  request_concurrency = 2

  [runners.docker]
    image = "alpine:3.19"
    privileged = false
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    pull_policy = "if-not-present"
    shm_size = 0
    tls_verify = true
    volumes = ['/cache']
    memory = "1024m"
    memory_swap = "1024m"

  [runners.cache]
    MaxUploadedArchiveSize = 0



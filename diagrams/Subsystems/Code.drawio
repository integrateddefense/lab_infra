        <mxCell id="ZaLJOxHt6rv1q8RytPqG-3" parent="1" style="whiteSpace=wrap;html=1;shape=mxgraph.basic.document;verticalAlign=top;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Deployment Contract&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;version: int&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;repo_path: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;before_sha: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;after_sha: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;timestamp: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;runs: list&lt;/div&gt;&lt;div style=&quot;text-align: center;&quot;&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-align: start; text-wrap-mode: nowrap; background-color: transparent;&quot;&gt;after%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20parent%3D%221%22%20style%3D%22whiteSpace%3Dwrap%3Bhtml%3D1%3Bshape%3Dmxgraph.basic.document%3BverticalAlign%3Dtop%3B%22%20value%3D%22%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3BGeneric%20Package%20API%26lt%3Bdiv%26gt%3Bdeployment-contract%26lt%3Bbr%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bmanual-deploy.json%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bauto-deploy.json%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20vertex%3D%221%22%3E%3CmxGeometry%20height%3D%22120%22%20width%3D%22130%22%20x%3D%22930%22%20y%3D%22120%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="130" x="940" y="180" as="geometry" />
        </mxCell>
        <mxCell id="ZaLJOxHt6rv1q8RytPqG-4" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Deployment Contract&lt;/h1&gt;&lt;div&gt;The Deployment Contract is an auditable JSON object that provides a reference to the code base and a specific set of actions to implement via ansible. Contracts are automatically generated based on files changed in a commit or merge to main, or based on user input, and registered as Generic Packages alongside the Release and Tag that they apply to.&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="320" x="880" y="20" as="geometry" />
        </mxCell>
        <mxCell id="ZaLJOxHt6rv1q8RytPqG-6" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;GitOps Coordination&lt;/h1&gt;&lt;div&gt;The GitOps Coordination section is a YAML-compliant block added to the release notes section for releases generated by the CI pipeline that allows multiple management pi nodes to coordinate and ensure jobs are executed once. It includes a statement of the jobs status, logging summary data including overall and per-command results, a claim expiration date that allows nodes to re-claim a job that may have failed during execution, and a nonce to avoid reliance on non-unique fields.&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="330" x="1300" y="20" as="geometry" />
        </mxCell>
        <mxCell id="ZaLJOxHt6rv1q8RytPqG-9" parent="1" style="whiteSpace=wrap;html=1;shape=mxgraph.basic.document;verticalAlign=top;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;GitOps Section&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;[GITOPS_BEGIN]&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;gitops:&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; status: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; claimed_by: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; expires_at: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; claim_nonce: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; result: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&amp;nbsp; summary: list&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;[GITOPS_END]&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="140" x="1440" y="220" as="geometry" />
        </mxCell>
        <mxCell id="ZaLJOxHt6rv1q8RytPqG-10" parent="1" style="whiteSpace=wrap;html=1;shape=mxgraph.basic.document;verticalAlign=top;" value="&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Runs List Entry&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap; background-color: transparent;&quot;&gt;after%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20parent%3D%221%22%20style%3D%22whiteSpace%3Dwrap%3Bhtml%3D1%3Bshape%3Dmxgraph.basic.document%3BverticalAlign%3Dtop%3B%22%20value%3D%22%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3BGeneric%20Package%20API%26lt%3Bdiv%26gt%3Bdeployment-contract%26lt%3Bbr%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bmanual-deploy.json%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bauto-deploy.json%26lt%3B%2Fdiv%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20vertex%3D%221%22%3E%3CmxGeometry%20height%3D%22120%22%20width%3D%22130%22%20x%3D%22930%22%20y%3D%22120%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;playbook: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;tags: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;priority: int&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;rule: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;file: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;reason: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;inventory: string&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;limit: string&lt;/div&gt;" vertex="1">
